#!/usr/bin/env bash
# claude — agent-fleet PATH shim.
#
# Injected into fleet panes' PATH via the server environment (ensure_server_env
# in bin/agent-fleet; AGENT_FLEET_SHIM=0 opts out). Hand-started `claude` —
# including `claude -r` / `--resume` / `-c` — execs the real binary with the
# fleet's status-hooks overlay attached, which is what gives these agents
# hook-tier status, notifications, the progress bar, and (via the hook's
# session-id capture) resume-after-reboot through persist-restore.
#
# Outside the fleet this file is not on PATH and nothing changes. Fleet-launched
# agents already carry the overlay explicitly and pass through untouched.

set -u

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# The real claude: first executable on PATH that isn't this shim.
real=""
IFS=: read -ra _dirs <<< "${PATH:-}"
for d in "${_dirs[@]}"; do
  [[ -z "$d" || "$d" == "$SELF_DIR" ]] && continue
  [[ -x "$d/claude" ]] && { real="$d/claude"; break; }
done
[[ -n "$real" ]] || { echo "agent-fleet claude shim: real claude not found on PATH" >&2; exit 127; }

# Pass through untouched when hooks make no sense (non-interactive / meta
# invocations) or when the caller already carries a settings overlay
# (fleet-launched agents, restored agents).
for a in "$@"; do
  case "$a" in
    -p|--print|--help|-h|--version|-V|--settings|--settings=*) exec "$real" "$@" ;;
  esac
done
[[ -n "${TMUX_PANE:-}" ]] || exec "$real" "$@"   # not in a tmux pane

# The hooks overlay (generated by the CLI; regenerate if missing).
overlay="${XDG_CACHE_HOME:-$HOME/.cache}/agent-fleet/hooks-settings.json"
if [[ ! -f "$overlay" && -n "${AGENT_FLEET_ROOT:-}" && -x "$AGENT_FLEET_ROOT/bin/agent-fleet" ]]; then
  overlay="$("$AGENT_FLEET_ROOT/bin/agent-fleet" hooks-file 2>/dev/null | tail -1)"
fi
[[ -f "$overlay" ]] || exec "$real" "$@"

exec "$real" --settings "$overlay" "$@"
