#!/usr/bin/env bash
# agent-fleet — a tmux-native session manager for Claude Code agents.
#
# Model (Phase 1)
# ---------------
#   workspace = a tmux SESSION on the isolated fleet socket (named for a dir)
#   agent     = a tmux WINDOW inside a workspace (one `claude` per window)
#   tab       = the native tmux window tab
#   pane      = a real PTY; an agent owns its window, split for sidecars
#
# Everything runs on a dedicated tmux socket (default: agent-fleet), fully
# isolated from your daily tmux server, config, and keybinds.
#
# The primary surface is a single fzf popup (Prefix o inside the fleet);
# this CLI is the verb layer the popup and your shell call.

set -euo pipefail

# --- Resolve install root (works whether invoked via symlink or direct path) ---
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"

AGENT_FLEET_VERSION="0.1.0"

CONF="${AGENT_FLEET_CONF:-$ROOT_DIR/conf/agent-fleet.conf}"
SOCKET="${AGENT_FLEET_SOCKET:-agent-fleet}"
DEFAULT_AGENT_CMD="${AGENT_FLEET_CMD:-claude}"
HOME_SESSION="${AGENT_FLEET_HOME_SESSION:-home}"

TMUX_BIN="${TMUX_BIN:-tmux}"
export AGENT_FLEET_ROOT="$ROOT_DIR"
export AGENT_FLEET_SOCKET="$SOCKET"
tx() { "$TMUX_BIN" -L "$SOCKET" -f "$CONF" "$@"; }

server_up() { tx list-sessions >/dev/null 2>&1; }

# True iff this shell is attached to the fleet's OWN tmux socket.
in_fleet_tmux() {
  [[ -n "${TMUX:-}" ]] && [[ "${TMUX%%,*}" == */"$SOCKET" ]]
}

# Push runtime locations into the server's global env so popup/keybind
# children (display-popup, run-shell) can resolve them.
ensure_server_env() {
  tx set-environment -g AGENT_FLEET_ROOT "$ROOT_DIR" 2>/dev/null || true
  tx set-environment -g AGENT_FLEET_SOCKET "$SOCKET" 2>/dev/null || true
}

sanitize_name() { echo "$1" | tr ':. /' '____'; }

AF_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/agent-fleet"

# Start the snapshot daemon (single writer the rails/picker read) if not already
# running. Self-deduping, so a stray extra launch just exits.
ensure_snapshotd() {
  local pf="$AF_CACHE_DIR/snapshotd.lock/pid"
  [[ -f "$pf" ]] && kill -0 "$(cat "$pf" 2>/dev/null)" 2>/dev/null && return 0
  AGENT_FLEET_SOCKET="$SOCKET" AGENT_FLEET_ROOT="$ROOT_DIR" \
    nohup "$ROOT_DIR/scripts/snapshotd.sh" >/dev/null 2>&1 &
}

# Guarantee a server exists with at least one session to attach to.
ensure_server() {
  if ! server_up; then
    # Fresh server: pane ids restart at %0, so per-pane state files from the
    # previous boot are stale (a leftover .session gate file would block the
    # hook from capturing new session ids). persist-restore purges too, but
    # this also covers the no-state fresh-boot path.
    rm -f "$AF_CACHE_DIR/panes/"*.status "$AF_CACHE_DIR/panes/"*.ackdone "$AF_CACHE_DIR/panes/"*.session 2>/dev/null || true
    # Cold boot (e.g. after a reboot): rebuild the last saved layout as shells if
    # we have one; otherwise start a fresh home workspace.
    if [[ -f "$AF_CACHE_DIR/fleet.state" ]] && "$ROOT_DIR/scripts/persist-restore.sh" 2>/dev/null; then
      :
    else
      tx new-session -d -s "$HOME_SESSION" -c "$HOME"
    fi
  fi
  ensure_server_env
  ensure_snapshotd
}

# Generate the fleet-scoped Claude settings file (hooks only). Launching an
# agent as `claude --settings <this>` overlays the status hooks on top of the
# user's global config without touching ~/.claude/settings.json.
ensure_hook_settings() {
  mkdir -p "$AF_CACHE_DIR/panes"
  local f="$AF_CACHE_DIR/hooks-settings.json"
  local hook="$ROOT_DIR/scripts/agent-status-hook.sh"
  cat > "$f" <<JSON
{
  "hooks": {
    "UserPromptSubmit": [ { "hooks": [ { "type": "command", "command": "'$hook' working $SOCKET" } ] } ],
    "PreToolUse":       [ { "matcher": "*", "hooks": [ { "type": "command", "command": "'$hook' working $SOCKET" } ] } ],
    "Notification":     [ { "hooks": [ { "type": "command", "command": "'$hook' wait $SOCKET" } ] } ],
    "Stop":             [ { "hooks": [ { "type": "command", "command": "'$hook' done $SOCKET" } ] } ]
  }
}
JSON
  printf '%s' "$f"
}

# The current session / window id, resolved from the calling pane (in-fleet).
current_session() { [[ -n "${TMUX_PANE:-}" ]] && tx display-message -p -t "$TMUX_PANE" '#S' 2>/dev/null; }
current_window()  { [[ -n "${TMUX_PANE:-}" ]] && tx display-message -p -t "$TMUX_PANE" '#{window_id}' 2>/dev/null; }

# Switch the fleet client to a target, or attach if we're in a bare shell.
# Refuses to hijack a foreign tmux server.
go_to_session() {
  local target="$1"
  if in_fleet_tmux; then
    tx switch-client -t "$target"
  elif [[ -n "${TMUX:-}" ]]; then
    echo "error: you're inside a different tmux server" >&2
    echo "       detach (Prefix-d) and run \`agent-fleet attach $target\` from a plain shell" >&2
    exit 1
  else
    exec "$TMUX_BIN" -L "$SOCKET" -f "$CONF" attach-session -t "$target"
  fi
}

# ---- subcommands -------------------------------------------------------------

# connect <dir|name> — resolve-or-create a workspace, then go to it.
#   - existing session name  -> switch to it
#   - a directory path       -> session named for its basename, cwd there
#   - any other name         -> session with that name, cwd $HOME
cmd_connect() {
  local arg="${1:-$PWD}" custom="${2:-}"

  # Existing session by that name → just switch (skip when forcing a new name).
  if [[ -z "$custom" ]] && server_up && tx has-session -t "$arg" 2>/dev/null; then
    ensure_server_env
    go_to_session "$arg"
    return 0
  fi

  local name dir
  if [[ -d "$arg" ]]; then
    dir="$(cd "$arg" && pwd)"
    name="$(sanitize_name "${custom:-$(basename "$dir")}")"
  else
    name="$(sanitize_name "${custom:-$arg}")"
    dir="$HOME"
  fi

  # new-session auto-starts the server if needed; no stray home session.
  if ! tx has-session -t "$name" 2>/dev/null; then
    tx new-session -d -s "$name" -c "$dir"
  fi
  ensure_server_env
  go_to_session "$name"
}

# add [name] — add an agent window to a workspace.
#   --to <session>          target workspace (default: current fleet session, else first)
#   --new-workspace <name>  put the agent in its own workspace <name> (create or reuse)
#   --cmd <command>         what to run     (default: $AGENT_FLEET_CMD = claude)
#   --dir <dir>             working dir      (default: target session's path, else $PWD)
# Prints the new pane id on success.
cmd_add() {
  local name="" target="" cmd="$DEFAULT_AGENT_CMD" dir="" focus="" cs="" cs_dir="" cmd_explicit="" new_ws=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)             target="$2"; shift 2 ;;
      --cmd)            cmd="$2"; cmd_explicit=1; shift 2 ;;
      --dir)            dir="$2"; cs_dir="$2"; shift 2 ;;
      --codespace|--cs) cs="$2"; shift 2 ;;
      --new-workspace)  new_ws="$2"; shift 2 ;;
      --focus)          focus=1; shift ;;
      --)               shift; break ;;
      *)     if [[ -z "$name" ]]; then name="$1"; else echo "error: unexpected arg: $1" >&2; exit 2; fi; shift ;;
    esac
  done
  # Codespace connections default to a shell — you run claude/tools yourself,
  # rather than booting straight into an agent. Override per-launch with --cmd,
  # or globally with AGENT_FLEET_CS_CMD (e.g. fish, zsh, or claude).
  [[ -n "$cs" && -z "$cmd_explicit" ]] && cmd="${AGENT_FLEET_CS_CMD:-bash}"

  if ! server_up; then
    echo "error: no fleet running — connect a workspace first" >&2
    exit 1
  fi
  ensure_server_env

  # --new-workspace: put the agent in its own workspace (a new session of that
  # name, or an existing one) rather than a tab in the current one.
  local ph_win=""
  if [[ -n "$new_ws" ]]; then
    new_ws="$(sanitize_name "$new_ws")"
    local wsdir="$dir"
    [[ -z "$wsdir" ]] && wsdir="$(tx display-message -p '#{pane_current_path}' 2>/dev/null || echo "$PWD")"
    if ! tx has-session -t "$new_ws" 2>/dev/null; then
      # Fresh session: its placeholder window is removed after the agent lands
      # (below), so the agent becomes the workspace's first tab — no stray shell.
      ph_win="$(tx new-session -d -P -F '#{window_id}' -s "$new_ws" -c "$wsdir" 2>/dev/null)"
    fi
    target="$new_ws"
    [[ -z "$dir" ]] && dir="$wsdir"
  fi

  if [[ -z "$target" ]]; then
    if in_fleet_tmux; then
      target="$(tx display-message -p '#S')"
    else
      target="$(tx list-sessions -F '#{session_name}' 2>/dev/null | head -1)"
    fi
  fi
  if [[ -z "$target" ]] || ! tx has-session -t "$target" 2>/dev/null; then
    echo "error: no such workspace: ${target:-<none>}" >&2
    exit 1
  fi

  if [[ -z "$dir" ]]; then
    dir="$(tx display-message -p -t "$target" '#{pane_current_path}' 2>/dev/null || echo "$PWD")"
  fi
  # Default the agent name to its workspace, so it reads "<workspace> · claude"
  # and follows the workspace on rename. Multiple agents per workspace is fine.
  [[ -z "$name" ]] && name="$target"

  # Label for the sidenav's agents list (first word of the command). Computed
  # from the *inner* command, before any codespace/hook wrapping.
  local label
  label="$(basename "${cmd%% *}")"

  if [[ -n "$cs" ]]; then
    # Codespace agent: runs over SSH via the wrapper, so the local Claude hooks
    # can't attach (they'd fire inside the codespace). Tracked by the scrape tier
    # instead. Pass an explicit remote dir through only when --dir was given.
    local env_pfx=""
    [[ -n "$cs_dir" ]] && env_pfx="AGENT_FLEET_CS_DIR='$cs_dir' "
    cmd="${env_pfx}'$ROOT_DIR/scripts/cs-connect.sh' '$cs' $cmd"
  elif [[ "$cmd" == "$DEFAULT_AGENT_CMD" || "$cmd" == "claude" ]]; then
    # Local claude agent: overlay the fleet status hooks. A custom --cmd is run
    # verbatim (no hooks, e.g. a plain shell).
    local hooks_file
    hooks_file="$(ensure_hook_settings)"
    cmd="$cmd --settings '$hooks_file'"
  fi

  local pane_id
  pane_id="$(tx new-window -P -F '#{pane_id}' -t "$target:" -n "$(sanitize_name "$name")" -c "$dir" "$cmd")"
  # Mark the agent so the sidenav lists it (per-pane, focus-independent) and so
  # workspace renames can follow it (per-window). Value = agent kind ("claude").
  tx set-option -p -t "$pane_id" @fleet-agent-kind "$label" 2>/dev/null || true
  tx set-option -w -t "$pane_id" @fleet-agent "$label" 2>/dev/null || true
  # Mark codespace agents as remote so the rail/daemon can treat them differently
  # (e.g. label the branch cell from `gh cs` rather than a local git checkout).
  [[ -n "$cs" ]] && tx set-option -p -t "$pane_id" @fleet-codespace "$cs" 2>/dev/null || true
  # Drop the placeholder window if we created the workspace for this agent, so the
  # agent is the workspace's first tab.
  [[ -n "$ph_win" ]] && tx kill-window -t "$ph_win" 2>/dev/null || true
  # Quick-add from a keybind wants to land on the new agent (switching workspace
  # first when the agent went into a new one).
  if [[ -n "$focus" ]]; then
    [[ -n "$new_ws" ]] && go_to_session "$new_ws" 2>/dev/null || true
    tx select-window -t "$pane_id" 2>/dev/null || true
  fi
  echo "$pane_id"
}

# goto <pane_id> — used by the picker: focus the exact agent pane.
cmd_goto() {
  local pane="${1:?usage: agent-fleet goto <pane_id>}"
  local loc sess winid
  loc="$(tx list-panes -a -F '#{pane_id} #{session_name} #{window_id}' 2>/dev/null \
        | awk -v p="$pane" '$1==p {print $2, $3; exit}')"
  if [[ -z "$loc" ]]; then
    echo "error: no such pane: $pane" >&2
    exit 1
  fi
  sess="${loc%% *}"
  winid="${loc##* }"
  # Visiting a finished agent clears its 'done' badge back to idle.
  "$ROOT_DIR/scripts/status.sh" clear-done "$pane" 2>/dev/null || true
  go_to_session "$sess"
  tx select-window -t "$winid" 2>/dev/null || true
  tx select-pane -t "$pane" 2>/dev/null || true
}

# back — jump to the previously focused pane (Prefix Tab). The focus-in hook
# keeps focus.prev current, so this just resolves and focuses it; landing there
# makes it the new "current", so pressing again toggles between the two.
cmd_back() {
  local prev_file="$AF_CACHE_DIR/focus.prev" p=""
  [[ -f "$prev_file" ]] && read -r p < "$prev_file" 2>/dev/null
  [[ -z "$p" ]] && exit 0
  # No-op silently if that pane is gone (don't error in a keybind).
  tx list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qx "$p" || exit 0
  cmd_goto "$p"
}

# attach [target] — sesh-style 3-way branch.
cmd_attach() {
  local target="${1:-}"
  ensure_server
  if [[ -n "$target" ]] && ! tx has-session -t "$target" 2>/dev/null; then
    echo "error: no such workspace: $target" >&2
    exit 1
  fi
  if in_fleet_tmux; then
    [[ -n "$target" ]] && tx switch-client -t "$target"
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    echo "error: you're inside a different tmux server — detach first" >&2
    exit 1
  fi
  if [[ -n "$target" ]]; then
    exec "$TMUX_BIN" -L "$SOCKET" -f "$CONF" attach-session -t "$target"
  else
    exec "$TMUX_BIN" -L "$SOCKET" -f "$CONF" attach-session
  fi
}

cmd_kill() {
  local target="${1:?usage: agent-fleet kill <session> | <session>:<window> | <pane_id>}"
  if [[ "$target" == %* ]]; then
    tx kill-pane -t "$target" && echo "killed pane $target"
  elif [[ "$target" == *:* ]]; then
    tx kill-window -t "$target" && echo "killed window $target"
  else
    tx kill-session -t "$target" && echo "killed workspace $target"
  fi
}

cmd_list() {
  if ! server_up; then
    echo "(fleet not running)"
    return 0
  fi
  tx list-sessions -F '#{session_name}' 2>/dev/null | sort | while read -r sess; do
    printf '\033[1;33m%s\033[0m\n' "$sess"
    tx list-windows -t "$sess" -F '  #{window_index}  #{window_name}  #{pane_current_path}' 2>/dev/null
  done
}

# rename-workspace [<old>] <new> — rename a workspace (tmux session).
# With one arg, renames the current workspace (run from inside the fleet).
cmd_rename_workspace() {
  local old new
  if [[ $# -ge 2 ]]; then old="$1"; new="$2"
  elif [[ $# -eq 1 ]]; then new="$1"; old="$(current_session)"
  else echo "usage: agent-fleet rename-workspace [<old>] <new>" >&2; exit 2; fi
  [[ -n "$old" ]] || { echo "error: no current workspace — run inside the fleet or pass <old>" >&2; exit 1; }
  new="$(sanitize_name "$new")"
  [[ "$old" == "$new" ]] && return 0
  tx rename-session -t "$old" "$new" || return 1
  # Agents named after the old workspace follow the rename.
  local wid wname tag
  while IFS='|' read -r wid wname tag; do
    [[ -n "$tag" && "$wname" == "$old" ]] && tx rename-window -t "$wid" "$new"
  done < <(tx list-windows -t "$new" -F '#{window_id}|#{window_name}|#{@fleet-agent}' 2>/dev/null)
  echo "workspace '$old' → '$new'"
}

# rename-tab [<target>] <new> — rename a tab (tmux window). Spaces allowed.
# With one arg, renames the current tab (run from inside the fleet).
cmd_rename_tab() {
  local target new
  if [[ $# -ge 2 ]]; then target="$1"; new="$2"
  elif [[ $# -eq 1 ]]; then new="$1"; target="$(current_window)"
  else echo "usage: agent-fleet rename-tab [<session:window>] <new>" >&2; exit 2; fi
  [[ -n "$target" ]] || { echo "error: no current tab — run inside the fleet or pass <target>" >&2; exit 1; }
  tx rename-window -t "$target" "$new" && echo "tab → '$new'"
}

# hooks-file — regenerate and print the path to the fleet's Claude settings
# overlay (hooks only). Useful for inspection or `claude --settings $(…)`.
cmd_hooks_file() {
  ensure_hook_settings
  echo
}

cmd_stop() {
  if ! server_up; then
    echo "fleet already stopped"
    return 0
  fi
  # Save the layout first so `agent-fleet attach` can rebuild it later.
  "$ROOT_DIR/scripts/persist-save.sh" 2>/dev/null || true
  local pf="$AF_CACHE_DIR/snapshotd.lock/pid"
  [[ -f "$pf" ]] && kill "$(cat "$pf" 2>/dev/null)" 2>/dev/null
  tx kill-server
  echo "fleet stopped"
}

# save — snapshot the current layout to the restore file (also done on a timer
# by the daemon and on `stop`).
cmd_save() {
  if ! server_up; then echo "fleet not running" >&2; exit 1; fi
  "$ROOT_DIR/scripts/persist-save.sh" && echo "layout saved"
}

# restore — rebuild the saved layout on a stopped fleet (attach does this
# automatically on a cold boot; this is the manual equivalent).
cmd_restore() {
  if server_up && tx list-sessions >/dev/null 2>&1; then
    echo "error: fleet already running — stop it first (agent-fleet stop)" >&2
    exit 1
  fi
  if "$ROOT_DIR/scripts/persist-restore.sh"; then
    ensure_server_env; ensure_snapshotd
    echo "layout restored — attach with: agent-fleet attach"
  else
    echo "nothing to restore" >&2; exit 1
  fi
}

# pick — open the fzf popup (when called from inside the fleet), else attach.
cmd_pick() {
  ensure_server
  if in_fleet_tmux; then
    tx display-popup -E -w 85% -h 80% "$ROOT_DIR/scripts/pick.sh"
  else
    cmd_attach
  fi
}

# cs <list|stop|connect> — light GitHub Codespaces helpers.
#   list            list your codespaces (passthrough to `gh codespace list`)
#   stop <name>     stop a running codespace
#   connect <name>  create-or-switch a workspace for the codespace and add a
#                   claude agent into it over SSH (used by the picker's cloud view)
cmd_cs() {
  command -v gh >/dev/null 2>&1 || { echo "error: 'gh' (GitHub CLI) not found on PATH" >&2; exit 1; }
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list|ls) gh codespace list "$@" ;;
    stop)    gh codespace stop -c "${1:?usage: agent-fleet cs stop <name>}" ;;
    connect|c)
      local cs="${1:?usage: agent-fleet cs connect <codespace-name> [workspace-name]}"
      local ws; ws="$(sanitize_name "${2:-$cs}")"
      ensure_server
      if tx has-session -t "$ws" 2>/dev/null; then ensure_server_env; go_to_session "$ws"; return 0; fi
      ensure_server_env
      # Lean-thin: the codespace IS the workspace — its first window is a shell
      # over SSH (not a proxied agent in the rail). Run a multiplexer inside for
      # more panes/agents. AGENT_FLEET_CS_CMD sets the shell; --cmd-style claude
      # agents still come from `add --codespace`.
      local cs_cmd="${AGENT_FLEET_CS_CMD:-bash}" pane
      pane="$(tx new-session -d -P -F '#{pane_id}' -s "$ws" -n "$ws" -c "$HOME" "'$ROOT_DIR/scripts/cs-connect.sh' '$cs' $cs_cmd")"
      tx set-option -p -t "$pane" @fleet-codespace "$cs" 2>/dev/null || true
      go_to_session "$ws"
      ;;
    *) echo "usage: agent-fleet cs {list | stop <name> | connect <name>}" >&2; exit 2 ;;
  esac
}

usage() {
  cat <<EOF
agent-fleet — tmux-native session manager for Claude Code agents.

Model:  workspace = tmux session   ·   agent = tmux window   ·   isolated socket

Verbs:
  agent-fleet connect <dir|name> [workspace-name]
                                   Resolve-or-create a workspace, then go to it. Optional name
                                   overrides the default (the directory's basename).
  agent-fleet attach [workspace]   Attach to the fleet (sesh-style 3-way branch).
  agent-fleet add [name] [--to <ws>] [--new-workspace <name>] [--cmd <cmd>] [--dir <dir>] [--codespace <name>]
                                   Add an agent window (default cmd: claude). --new-workspace puts it
                                   in its own workspace instead of a tab. --codespace runs it inside a
                                   GitHub Codespace over SSH (defaults to a shell). Prints its pane id.
  agent-fleet cs <list | stop <name> | connect <name> [workspace-name]>
                                   Codespaces: list / stop / connect (opens a shell workspace).
  agent-fleet goto <pane_id>       Focus a specific agent pane (used by the picker).
  agent-fleet rename-workspace [<old>] <new>   Rename a workspace (session).
  agent-fleet rename-tab [<target>] <new>      Rename a tab (window).
  agent-fleet kill <target>        Kill a workspace, window (<ws>:<win>), or pane (%id).
  agent-fleet list                 List workspaces and their agents.
  agent-fleet pick                 Open the fzf picker popup (or attach from a bare shell).
  agent-fleet save                 Snapshot the layout to disk (also auto-saved + saved on stop).
  agent-fleet restore              Rebuild the saved layout on a stopped fleet (attach does this on boot).
  agent-fleet stop                 Save the layout, then kill the fleet server.

Env:
  AGENT_FLEET_CONF     Base tmux config (default: <repo>/conf/agent-fleet.conf)
  AGENT_FLEET_SOCKET   tmux socket name (default: agent-fleet)
  AGENT_FLEET_CMD      Default agent command (default: claude)

User overrides: ~/.config/agent-fleet/local.conf is sourced by the base config if present.
EOF
}

main() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    connect|c)  cmd_connect "$@" ;;
    attach|a)   cmd_attach "$@" ;;
    add)        cmd_add "$@" ;;
    goto)       cmd_goto "$@" ;;
    back)       cmd_back "$@" ;;
    rename-workspace|rename-ws) cmd_rename_workspace "$@" ;;
    rename-tab|rename-window)   cmd_rename_tab "$@" ;;
    kill|rm)    cmd_kill "$@" ;;
    list|ls)    cmd_list "$@" ;;
    pick)       cmd_pick "$@" ;;
    cs)         cmd_cs "$@" ;;
    hooks-file) cmd_hooks_file "$@" ;;
    save)       cmd_save "$@" ;;
    restore)    cmd_restore "$@" ;;
    stop)       cmd_stop "$@" ;;
    -V|--version|version) echo "agent-fleet $AGENT_FLEET_VERSION" ;;
    -h|--help|help) usage ;;
    "")         cmd_attach ;;
    *)          echo "unknown subcommand: $sub" >&2; usage; exit 2 ;;
  esac
}

main "$@"
